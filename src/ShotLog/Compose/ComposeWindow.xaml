<Window x:Class="ShotLog.Compose.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ShotLog.Resources"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{x:Static res:Strings.Compose_Title}" Height="720" Width="1400" MinWidth="980" Icon="/Assets/shotlog.ico"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen">
  <Grid Margin="18">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0.7*"/>
      <ColumnDefinition Width="12"/>
      <ColumnDefinition Width="1*"/>
      <ColumnDefinition Width="12"/>
      <ColumnDefinition Width="1.1*"/>
    </Grid.ColumnDefinitions>

    <!-- ===== left: filters + selectable list ===== -->
    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0">
        <TextBlock Text="{x:Static res:Strings.Compose_GroupBy}" Style="{StaticResource SectionLabel}"/>
        <TextBlock Text="{x:Static res:Strings.Common_Tags}" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,6"/>
        <WrapPanel x:Name="TagFilter"/>
        <TextBlock Text="{x:Static res:Strings.Common_Preset}" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,4,0,6"/>
        <WrapPanel x:Name="PresetFilter"/>
        <TextBlock Text="{x:Static res:Strings.Compose_Period}" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,4,0,6"/>
        <WrapPanel x:Name="DateFilter"/>
      </StackPanel>

      <TextBlock x:Name="CountLabel" Grid.Row="1" Style="{StaticResource SectionLabel}" Margin="0,6,0,8"/>

      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <ItemsControl x:Name="List">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                      BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <CheckBox Grid.Column="0" IsChecked="{Binding Selected, Mode=TwoWay}"
                            VerticalAlignment="Center" Margin="2,0,10,0"/>
                  <Border Grid.Column="1" CornerRadius="7" BorderBrush="#FF2A3340" BorderThickness="1"
                          ClipToBounds="True" Height="58" Background="#FF0B0F15">
                    <Image Source="{Binding Thumb}" Stretch="UniformToFill"/>
                  </Border>
                  <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimeText}" FontSize="11.5" Foreground="{StaticResource TextDim}"/>
                    <TextBlock Text="{Binding MemoSnippet}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                  Background="{StaticResource Border}"/>

    <!-- ===== right: title + output + preview ===== -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="{x:Static res:Strings.Compose_TitleLabel}" Style="{StaticResource SectionLabel}"/>
      <TextBox x:Name="TitleBox" Grid.Row="1" Style="{StaticResource FieldBox}"
               TextChanged="OnAnyChanged" Margin="0,0,0,12"/>

      <TextBlock Grid.Row="2" Text="{x:Static res:Strings.Compose_OutputFolder}" Style="{StaticResource SectionLabel}"/>
      <Grid Grid.Row="3" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="OutputBox" Grid.Column="0" Style="{StaticResource FieldBox}"/>
        <Button Grid.Column="1" Content="{x:Static res:Strings.Common_Browse}" Style="{StaticResource Btn}" Margin="10,0,0,0" Click="OnBrowse"/>
      </Grid>

      <Grid Grid.Row="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{x:Static res:Strings.Compose_Preview}" Style="{StaticResource SectionLabel}"/>
        <Border Grid.Row="1" Background="#FF0B0F15" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
          <TextBox x:Name="PreviewBox" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                   Foreground="#FFC5D0DB" FontFamily="Consolas, D2Coding, monospace" FontSize="12"
                   Padding="12" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Auto"/>
        </Border>
      </Grid>

      <Grid Grid.Row="5" Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <CheckBox x:Name="FrontMatterBox" Grid.Column="0" Content="{x:Static res:Strings.Compose_IncludeFrontMatter}"
                  VerticalAlignment="Center" Click="OnAnyChanged"/>
        <TextBlock x:Name="StatusLabel" Grid.Column="1" VerticalAlignment="Center" Margin="14,0,14,0"
                   Foreground="{StaticResource TextDim}" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal">
          <Button x:Name="CopyMdBtn" Content="{x:Static res:Strings.Compose_CopyMarkdown}" Style="{StaticResource Btn}" Click="OnCopyMarkdown" Margin="0,0,10,0"/>
          <Button x:Name="HtmlBtn" Content="{x:Static res:Strings.Compose_ExportHtml}" Style="{StaticResource Btn}" Click="OnExportHtml" Margin="0,0,10,0"/>
          <Button x:Name="GenerateBtn" Content="{x:Static res:Strings.Compose_CreateAndOpen}" Style="{StaticResource BtnPrimary}" Click="OnGenerate"/>
        </StackPanel>
      </Grid>
    </Grid>

    <GridSplitter Grid.Column="3" Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                  Background="{StaticResource Border}"/>

    <!-- ===== far right: rendered Markdown preview (WebView2) ===== -->
    <Grid Grid.Column="4">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Text="{x:Static res:Strings.Compose_RenderedPreview}" Style="{StaticResource SectionLabel}"/>
      <Border Grid.Row="1" Background="#FF0D1117" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid>
          <wv2:WebView2 x:Name="RenderView"/>
          <TextBlock x:Name="WebMissingHint" Visibility="Collapsed" Margin="20"
                     Foreground="{StaticResource TextDim}" TextWrapping="Wrap" TextAlignment="Center"
                     VerticalAlignment="Center" HorizontalAlignment="Center"
                     Text="{x:Static res:Strings.Compose_WebViewMissing}"/>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
