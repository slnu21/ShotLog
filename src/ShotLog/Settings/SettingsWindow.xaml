<Window x:Class="ShotLog.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ShotLog.Resources"
        Title="{x:Static res:Strings.Settings_Title}" Height="720" Width="680" Icon="/Assets/shotlog.ico"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style x:Key="Group" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Surface}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>
    <Style x:Key="MiniLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="2,0,0,4"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="18,18,18,18">
      <StackPanel>
        <!-- presets -->
        <TextBlock Text="{x:Static res:Strings.Settings_PresetsSection}" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <ItemsControl x:Name="PresetList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Group}">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{x:Static res:Strings.Settings_Name}" Style="{StaticResource MiniLabel}"/>
                      <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{x:Static res:Strings.Common_Delete}" Style="{StaticResource Btn}" Padding="12,8"
                            VerticalAlignment="Bottom" Margin="10,0,0,0" Click="OnRemovePreset" Tag="{Binding}"/>
                  </Grid>
                  <TextBlock Text="{x:Static res:Strings.Settings_Folder}" Style="{StaticResource MiniLabel}" Margin="2,10,0,4"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FolderPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    <Button Grid.Column="1" Content="{x:Static res:Strings.Common_Browse}" Style="{StaticResource Btn}" Margin="10,0,0,0" Click="OnBrowsePreset" Tag="{Binding}"/>
                  </Grid>
                  <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                      <TextBlock Text="{x:Static res:Strings.Settings_DefaultTags}" Style="{StaticResource MiniLabel}"/>
                      <TextBox Text="{Binding TagsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{x:Static res:Strings.Settings_Color}" Style="{StaticResource MiniLabel}"/>
                      <TextBox Text="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="{x:Static res:Strings.Settings_AddPreset}" Style="{StaticResource Btn}" HorizontalAlignment="Left" Click="OnAddPreset" Margin="0,0,0,18"/>

        <!-- hotkeys -->
        <TextBlock Text="{x:Static res:Strings.Settings_HotkeysSection}" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <Border Style="{StaticResource Group}">
          <StackPanel>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static res:Strings.Settings_HkInstant}" VerticalAlignment="Center"/>
              <TextBox x:Name="InstantBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static res:Strings.Settings_HkNote}" VerticalAlignment="Center"/>
              <TextBox x:Name="NoteBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static res:Strings.Settings_HkRegion}" VerticalAlignment="Center"/>
              <TextBox x:Name="RegionBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static res:Strings.Settings_HkWindow}" VerticalAlignment="Center"/>
              <TextBox x:Name="WindowBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static res:Strings.Settings_HkClipboard}" VerticalAlignment="Center"/>
              <TextBox x:Name="ClipboardBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static res:Strings.Settings_HkInbox}" VerticalAlignment="Center"/>
              <TextBox x:Name="InboxBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <TextBlock Text="{x:Static res:Strings.Settings_HotkeyHint}" Style="{StaticResource MiniLabel}" Margin="2,10,0,0"/>
          </StackPanel>
        </Border>

        <!-- export -->
        <TextBlock Text="{x:Static res:Strings.Settings_ExportSection}" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <Border Style="{StaticResource Group}">
          <StackPanel>
            <TextBlock Text="{x:Static res:Strings.Settings_DefaultOutputFolder}" Style="{StaticResource MiniLabel}"/>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <TextBox x:Name="ExportRootBox" Grid.Column="0" Style="{StaticResource FieldBox}"/>
              <Button Grid.Column="1" Content="{x:Static res:Strings.Common_Browse}" Style="{StaticResource Btn}" Margin="10,0,0,0" Click="OnBrowseExport"/>
            </Grid>
            <CheckBox x:Name="SidecarCheck" Margin="0,14,0,0"
                      Content="{x:Static res:Strings.Settings_Sidecar}"/>
            <CheckBox x:Name="NotifyCheck" Margin="0,10,0,0" Content="{x:Static res:Strings.Settings_Notify}"/>
          </StackPanel>
        </Border>

        <!-- general -->
        <TextBlock Text="{x:Static res:Strings.Settings_GeneralSection}" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <Border Style="{StaticResource Group}">
          <StackPanel>
            <CheckBox x:Name="AutoStartCheck" Content="{x:Static res:Strings.Settings_AutoStart}"/>
            <TextBlock Text="{x:Static res:Strings.Settings_Language}" Style="{StaticResource MiniLabel}" Margin="2,14,0,4"/>
            <ComboBox x:Name="LanguageBox" Width="220" HorizontalAlignment="Left">
              <ComboBoxItem Content="{x:Static res:Strings.Settings_LangSystem}"/>
              <ComboBoxItem Content="한국어"/>
              <ComboBoxItem Content="English"/>
            </ComboBox>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- footer -->
    <Border Grid.Row="1" Background="#FF11161D" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,12">
        <Button Content="{x:Static res:Strings.Common_Close}" Style="{StaticResource Btn}" Click="OnClose" Margin="0,0,10,0"/>
        <Button Content="{x:Static res:Strings.Common_Save}" Style="{StaticResource BtnPrimary}" Click="OnSave"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
