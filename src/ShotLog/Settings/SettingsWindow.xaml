<Window x:Class="ShotLog.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShotLog — 설정" Height="720" Width="680" Icon="/Assets/shotlog.ico"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style x:Key="Group" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Surface}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>
    <Style x:Key="MiniLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="2,0,0,4"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="18,18,18,18">
      <StackPanel>
        <!-- presets -->
        <TextBlock Text="프리셋 (저장 위치)" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <ItemsControl x:Name="PresetList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Group}">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="이름" Style="{StaticResource MiniLabel}"/>
                      <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="삭제" Style="{StaticResource Btn}" Padding="12,8"
                            VerticalAlignment="Bottom" Margin="10,0,0,0" Click="OnRemovePreset" Tag="{Binding}"/>
                  </Grid>
                  <TextBlock Text="폴더" Style="{StaticResource MiniLabel}" Margin="2,10,0,4"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FolderPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    <Button Grid.Column="1" Content="찾아보기" Style="{StaticResource Btn}" Margin="10,0,0,0" Click="OnBrowsePreset" Tag="{Binding}"/>
                  </Grid>
                  <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                      <TextBlock Text="기본 태그 (쉼표)" Style="{StaticResource MiniLabel}"/>
                      <TextBox Text="{Binding TagsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="색상 (#RRGGBB)" Style="{StaticResource MiniLabel}"/>
                      <TextBox Text="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="+ 프리셋 추가" Style="{StaticResource Btn}" HorizontalAlignment="Left" Click="OnAddPreset" Margin="0,0,0,18"/>

        <!-- hotkeys -->
        <TextBlock Text="단축키" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <Border Style="{StaticResource Group}">
          <StackPanel>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="즉시 캡처 → 활성 프리셋" VerticalAlignment="Center"/>
              <TextBox x:Name="InstantBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="캡처 + 메모" VerticalAlignment="Center"/>
              <TextBox x:Name="NoteBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="영역 선택 캡처" VerticalAlignment="Center"/>
              <TextBox x:Name="RegionBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="활성 창 캡처" VerticalAlignment="Center"/>
              <TextBox x:Name="WindowBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
              <TextBlock Text="인박스 열기" VerticalAlignment="Center"/>
              <TextBox x:Name="InboxBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
            </Grid>
            <TextBlock Text="형식: Ctrl+Alt+S, Ctrl+Shift+1 …  (변경은 저장 시 적용)" Style="{StaticResource MiniLabel}" Margin="2,10,0,0"/>
          </StackPanel>
        </Border>

        <!-- export -->
        <TextBlock Text="내보내기" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <Border Style="{StaticResource Group}">
          <StackPanel>
            <TextBlock Text="기본 출력 폴더" Style="{StaticResource MiniLabel}"/>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <TextBox x:Name="ExportRootBox" Grid.Column="0" Style="{StaticResource FieldBox}"/>
              <Button Grid.Column="1" Content="찾아보기" Style="{StaticResource Btn}" Margin="10,0,0,0" Click="OnBrowseExport"/>
            </Grid>
            <CheckBox x:Name="SidecarCheck" Margin="0,14,0,0"
                      Content="PNG 옆에 같은 이름 .md 사이드카 생성 (탐색기에서도 메모 확인)"/>
            <CheckBox x:Name="NotifyCheck" Margin="0,10,0,0" Content="즉시 캡처 후 트레이 알림 표시"/>
          </StackPanel>
        </Border>

        <!-- general -->
        <TextBlock Text="일반" Style="{StaticResource SectionLabel}" FontSize="12"/>
        <Border Style="{StaticResource Group}">
          <CheckBox x:Name="AutoStartCheck" Content="Windows 시작 시 자동 실행"/>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- footer -->
    <Border Grid.Row="1" Background="#FF11161D" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,12">
        <Button Content="닫기" Style="{StaticResource Btn}" Click="OnClose" Margin="0,0,10,0"/>
        <Button Content="저장" Style="{StaticResource BtnPrimary}" Click="OnSave"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
