<Window x:Class="ShotLog.Capture.QuickNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ShotLog.Resources"
        Title="{x:Static res:Strings.QuickNote_Title}" Icon="/Assets/shotlog.ico"
        Width="384" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="Manual">
  <Border Margin="12" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="14">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <StackPanel Margin="16">
      <!-- header -->
      <Grid Margin="0,0,0,12">
        <TextBlock Text="{x:Static res:Strings.QuickNote_Header}" FontSize="14" FontWeight="Bold"/>
        <Button x:Name="CloseBtn" Style="{StaticResource IconBtn}" Width="26" Height="26"
                HorizontalAlignment="Right" Content="✕" Click="OnDiscard"/>
      </Grid>

      <!-- preview -->
      <Border CornerRadius="10" BorderBrush="#FF2A3340" BorderThickness="1" ClipToBounds="True"
              MaxHeight="168" Background="#FF0B0F15">
        <Image x:Name="Preview" Stretch="Uniform" StretchDirection="DownOnly"/>
      </Border>
      <TextBlock x:Name="MapLabel" Margin="2,9,0,2" FontSize="12" Foreground="{StaticResource Tag}"/>

      <!-- preset -->
      <TextBlock Text="{x:Static res:Strings.QuickNote_SaveLocation}" Style="{StaticResource SectionLabel}" Margin="0,14,0,8"/>
      <WrapPanel x:Name="PresetPanel"/>

      <!-- tags -->
      <TextBlock Text="{x:Static res:Strings.Common_Tags}" Style="{StaticResource SectionLabel}" Margin="0,8,0,8"/>
      <WrapPanel x:Name="TagPanel"/>
      <TextBox x:Name="TagInput" Style="{StaticResource FieldBox}" KeyDown="OnTagKeyDown"
               Tag="{x:Static res:Strings.QuickNote_TagsWatermark}"/>

      <!-- memo -->
      <TextBlock Text="{x:Static res:Strings.QuickNote_Memo}" Style="{StaticResource SectionLabel}" Margin="0,14,0,8"/>
      <TextBox x:Name="MemoBox" Style="{StaticResource FieldBox}" Height="84"
               AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
               VerticalScrollBarVisibility="Auto" PreviewKeyDown="OnMemoKeyDown"/>
      <TextBlock Margin="2,7,0,0" FontSize="11" Foreground="{StaticResource TextDim}"
                 Text="{x:Static res:Strings.QuickNote_Hint}"/>

      <!-- actions -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button Content="{x:Static res:Strings.Common_Copy}" Style="{StaticResource Btn}" Click="OnCopy" Margin="0,0,10,0"/>
        <Button Content="{x:Static res:Strings.QuickNote_Annotate}" Style="{StaticResource Btn}" Click="OnAnnotate" Margin="0,0,10,0"/>
        <Button Content="{x:Static res:Strings.QuickNote_Discard}" Style="{StaticResource Btn}" Click="OnDiscard" Margin="0,0,10,0"/>
        <Button x:Name="SaveBtn" Content="{x:Static res:Strings.Common_Save}" Style="{StaticResource BtnPrimary}" Click="OnSave"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
