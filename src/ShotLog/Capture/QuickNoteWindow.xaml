<Window x:Class="ShotLog.Capture.QuickNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShotLog — 캡처 메모" Icon="/Assets/shotlog.ico"
        Width="384" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="Manual">
  <Border Margin="12" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="14">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <StackPanel Margin="16">
      <!-- header -->
      <Grid Margin="0,0,0,12">
        <TextBlock Text="캡처에 메모" FontSize="14" FontWeight="Bold"/>
        <Button x:Name="CloseBtn" Style="{StaticResource IconBtn}" Width="26" Height="26"
                HorizontalAlignment="Right" Content="✕" Click="OnDiscard"/>
      </Grid>

      <!-- preview -->
      <Border CornerRadius="10" BorderBrush="#FF2A3340" BorderThickness="1" ClipToBounds="True"
              MaxHeight="168" Background="#FF0B0F15">
        <Image x:Name="Preview" Stretch="Uniform" StretchDirection="DownOnly"/>
      </Border>
      <TextBlock x:Name="MapLabel" Margin="2,9,0,2" FontSize="12" Foreground="{StaticResource Tag}"/>

      <!-- preset -->
      <TextBlock Text="저장 위치 (프리셋)" Style="{StaticResource SectionLabel}" Margin="0,14,0,8"/>
      <WrapPanel x:Name="PresetPanel"/>

      <!-- tags -->
      <TextBlock Text="태그" Style="{StaticResource SectionLabel}" Margin="0,8,0,8"/>
      <WrapPanel x:Name="TagPanel"/>
      <TextBox x:Name="TagInput" Style="{StaticResource FieldBox}" KeyDown="OnTagKeyDown"
               Tag="태그 입력 후 Enter"/>

      <!-- memo -->
      <TextBlock Text="메모" Style="{StaticResource SectionLabel}" Margin="0,14,0,8"/>
      <TextBox x:Name="MemoBox" Style="{StaticResource FieldBox}" Height="84"
               AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
               VerticalScrollBarVisibility="Auto" PreviewKeyDown="OnMemoKeyDown"/>
      <TextBlock Margin="2,7,0,0" FontSize="11" Foreground="{StaticResource TextDim}"
                 Text="Enter 저장 · Shift+Enter 줄바꿈 · Esc 버리기"/>

      <!-- actions -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button Content="버리기" Style="{StaticResource Btn}" Click="OnDiscard" Margin="0,0,10,0"/>
        <Button x:Name="SaveBtn" Content="저장" Style="{StaticResource BtnPrimary}" Click="OnSave"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
