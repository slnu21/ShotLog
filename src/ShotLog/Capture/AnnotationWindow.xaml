<Window x:Class="ShotLog.Capture.AnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ShotLog.Resources"
        Title="{x:Static res:Strings.Annot_Title}" Icon="/Assets/shotlog.ico"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen"
        MinWidth="640" MinHeight="480">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- toolbar (populated in code-behind) -->
    <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
            BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,0,0,10">
      <WrapPanel x:Name="ToolBar" Orientation="Horizontal"/>
    </Border>

    <!-- drawing surface -->
    <Border Grid.Row="1" Background="#FF0B0F15" BorderBrush="{StaticResource Border}"
            BorderThickness="1" CornerRadius="10" ClipToBounds="True">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="6">
        <InkCanvas x:Name="Surface" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent"/>
      </ScrollViewer>
    </Border>

    <!-- footer -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button x:Name="CancelBtn" Style="{StaticResource Btn}" Margin="0,0,10,0" Click="OnCancel"/>
      <Button x:Name="DoneBtn" Style="{StaticResource BtnPrimary}" Click="OnDone" MinWidth="96"/>
    </StackPanel>
  </Grid>
</Window>
