<Window x:Class="ShotLog.Dialogs.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ShotLog.Resources"
        Width="300" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <Border Margin="12" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="14">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <StackPanel Margin="20">
      <Grid x:Name="HeaderBar" Margin="0,0,0,12" Background="Transparent">
        <TextBlock Text="{x:Static res:Strings.Settings_Color}" FontSize="15" FontWeight="Bold"/>
      </Grid>

      <WrapPanel x:Name="SwatchPanel"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button x:Name="CancelBtn" Style="{StaticResource Btn}" Margin="0,0,10,0" Click="OnCancel"
                Content="{x:Static res:Strings.Common_Cancel}"/>
        <Button x:Name="CustomBtn" Style="{StaticResource BtnPrimary}" Click="OnCustom" MinWidth="84"
                Content="{x:Static res:Strings.Picker_Custom}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
