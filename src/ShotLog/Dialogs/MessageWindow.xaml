<Window x:Class="ShotLog.Dialogs.MessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="410" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <Border Margin="12" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="14">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <StackPanel Margin="20">
      <!-- header (drag handle) -->
      <Grid x:Name="HeaderBar" Margin="0,0,0,12" Background="Transparent">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="IconText" Grid.Column="0" FontFamily="Segoe UI Symbol" FontSize="20"
                   Margin="0,0,12,0" VerticalAlignment="Center"/>
        <TextBlock x:Name="TitleText" Grid.Column="1" FontSize="15" FontWeight="Bold"
                   VerticalAlignment="Center" TextWrapping="Wrap"/>
      </Grid>

      <TextBlock x:Name="MessageText" Foreground="{StaticResource TextMuted}" FontSize="13" TextWrapping="Wrap"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
        <Button x:Name="CancelBtn" Style="{StaticResource Btn}" Margin="0,0,10,0" Click="OnCancel"/>
        <Button x:Name="OkBtn" Style="{StaticResource BtnPrimary}" Click="OnOk" MinWidth="84"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
