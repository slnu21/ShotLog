<Window x:Class="ShotLog.Dialogs.PresetPickWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:ShotLog.Resources"
        Width="440" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <Border Margin="12" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
          BorderThickness="1" CornerRadius="14">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <StackPanel Margin="20">
      <Grid x:Name="HeaderBar" Margin="0,0,0,12" Background="Transparent">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="📁" FontFamily="Segoe UI Symbol" FontSize="18"
                   Margin="0,0,12,0" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Inbox_MoveTitle}" FontSize="15" FontWeight="Bold"
                   VerticalAlignment="Center" TextWrapping="Wrap"/>
      </Grid>

      <TextBlock Text="{x:Static res:Strings.Inbox_MovePrompt}" Foreground="{StaticResource TextMuted}"
                 FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,10"/>

      <Border Background="{StaticResource Field}" BorderBrush="{StaticResource Border}" BorderThickness="1"
              CornerRadius="8" Padding="6" MaxHeight="240">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="PresetPanel"/>
        </ScrollViewer>
      </Border>

      <CheckBox x:Name="ReplaceTagsCheck" Margin="2,14,0,0"
                Content="{x:Static res:Strings.Inbox_MoveReplaceTags}"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
        <Button x:Name="CancelBtn" Style="{StaticResource Btn}" Margin="0,0,10,0" Click="OnCancel"
                Content="{x:Static res:Strings.Common_Cancel}"/>
        <Button x:Name="OkBtn" Style="{StaticResource BtnPrimary}" Click="OnOk" MinWidth="84"
                Content="{x:Static res:Strings.Inbox_MoveTitle}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
